{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dit.uoa.gr/curriculum/schema/course.schema.json",
  "title": "Course",
  "description": "A single course in the DIT@EKPA undergraduate programme (2026 PPS proposal). One JSON file per course, keyed by its code.",
  "type": "object",
  "additionalProperties": false,
  "required": ["code", "title", "category", "ects"],
  "properties": {
    "code": {
      "$ref": "#/$defs/courseCode",
      "description": "Natural key, e.g. Κ17, Κ20β, ΘΠ01, ΚΤΝ1, ΣΕ3, ΥΣ16α."
    },
    "title": { "$ref": "#/$defs/bilingual" },
    "category": {
      "type": "string",
      "description": "Curriculum bucket the course belongs to under the 2026 PPS.",
      "enum": [
        "core",
        "basic",
        "capstone",
        "standalone_lab",
        "elective",
        "thesis",
        "internship"
      ]
    },
    "hours": {
      "type": "object",
      "description": "Weekly teaching hours: Θεωρία / Φροντιστήριο / Εργαστήριο.",
      "additionalProperties": false,
      "required": ["theory", "tutorial", "lab"],
      "properties": {
        "theory": { "type": "integer", "minimum": 0 },
        "tutorial": { "type": "integer", "minimum": 0 },
        "lab": { "type": "integer", "minimum": 0 }
      }
    },
    "ects": {
      "type": "number",
      "exclusiveMinimum": 0,
      "maximum": 30,
      "description": "ECTS credits."
    },
    "semester": {
      "type": "array",
      "description": "Semester(s) in which the course is offered (1-8). Most courses have one; a few list two.",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "integer", "minimum": 1, "maximum": 8 }
    },
    "prerequisites": {
      "type": "array",
      "description": "Prerequisite courses (Προαπαιτούμενα), as listed in the PPS course tables.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["code", "type"],
        "properties": {
          "code": { "$ref": "#/$defs/courseCode" },
          "type": { "type": "string", "enum": ["required", "recommended"] }
        }
      }
    },
    "offered_this_year": {
      "type": "boolean",
      "description": "Whether the course is offered this academic year. Defaults to true.",
      "default": true
    },
    "instructors": {
      "type": "array",
      "description": "Teaching staff, where known.",
      "items": { "type": "string", "minLength": 1 }
    },
    "description_url": {
      "type": "string",
      "format": "uri",
      "description": "Optional link to the external analytical course description."
    },
    "notes": {
      "type": "string",
      "description": "Free text for edge cases or data-entry caveats."
    }
  },
  "$defs": {
    "courseCode": {
      "type": "string",
      "pattern": "^[A-Za-zΑ-Ωα-ωΐΰίϊόάέύϋήώ0-9]{2,12}$"
    },
    "bilingual": {
      "type": "object",
      "additionalProperties": false,
      "required": ["el"],
      "properties": {
        "el": { "type": "string", "minLength": 1, "description": "Greek (source of truth)." },
        "en": { "type": "string", "minLength": 1, "description": "English (optional)." }
      }
    }
  }
}
